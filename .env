# Variables de entorno para mcp_server.py

# Clave API para Deepseek
DEEPSEEK_API_KEY="TU_DEEPSEEK_API_KEY_AQUI"

# Credenciales de la aplicación Autodesk Platform Services
AUTODESK_CLIENT_ID="TU_AUTODESK_CLIENT_ID_AQUI"
AUTODESK_CLIENT_SECRET="TU_AUTODESK_CLIENT_SECRET_AQUI"

# URI de redirección configurado en tu aplicación Autodesk
# Asegúrate de que coincida con la ruta y puerto donde se ejecutará el servidor FastMCP
# Ejemplo si el servidor corre en http://127.0.0.1:8000 y el callback es /autodesk/callback
AUTODESK_REDIRECT_URI="http://127.0.0.1:8000/autodesk/callback"

# (Opcional) Alcances (scopes) que tu aplicación necesita. Separados por espacio.
# Ejemplo: AUTODESK_SCOPES="data:read viewables:read"
AUTODESK_SCOPES="data:read data:write bucket:create bucket:read"
