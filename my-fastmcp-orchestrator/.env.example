# This is an example environment configuration file.
# Copy this file to .env and fill in your actual credentials and settings.
# Do NOT commit your actual .env file to version control if it contains sensitive data.

# --- FastMCP Server Configuration ---
# URL of your FastMCP WebSocket server
FASTMCP_URL=ws://localhost:8765
# Optional: If port is specified separately and needs to override the port in FASTMCP_URL.
# The fastmcp_client will prioritize the FASTMCP_PORT if both are set and FASTMCP_PORT is passed to connect().
# However, the current client implementation in connect() will parse FASTMCP_URL by default.
# If you provide a port to fastmcp_client.connect(port=XXXX), that will take precedence.
# FASTMCP_PORT=8765
# Authentication token for the FastMCP server, if required.
FASTMCP_TOKEN=your_fastmcp_server_access_token

# --- AI Controller Configuration (Google Gemini AI) ---
# Your API Key for Google Gemini (generative-ai).
# Obtain this from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_or_other_llm_api_key_here

# --- OAuth2 Configuration for AI Controller (Alternative, if not using API Key) ---
# These are example variables if you were to implement OAuth2 authentication
# with a service like Google Cloud Identity Platform for accessing Google APIs.
# The current ai_controller.py has placeholder logic for OAuth2 and would need
# full implementation using a library like 'google-auth'.

# OAUTH_CLIENT_ID=your_oauth_client_id_from_google_cloud_console
# OAUTH_CLIENT_SECRET=your_oauth_client_secret_from_google_cloud_console
# OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token # Or your identity provider's token URL
# OAUTH_SCOPES=https://www.googleapis.com/auth/generative-language.tuning # Example scope for Gemini

# If using OAuth2 with a local credentials file (e.g., for service accounts or user flow):
# OAUTH_CREDENTIALS_PATH=/path/to/your/credentials.json


# --- Application Specific Configurations (Optional Examples) ---
# You can add environment variables for specific application clients if needed.
# For example, default paths, connection details for specific app instances, etc.

# Example for Revit Client:
# REVIT_DEFAULT_PROJECT_PATH="C:/Path/To/Your/DefaultRevitProject.rvt"
# REVIT_ADDIN_URL="http://localhost:8080/revit_api" # If Revit has an add-in with an HTTP API

# Example for ArcGIS Client (alternative to direct credential passing in code):
# ARCGIS_PORTAL_URL="https://yourportal.example.com/portal"
# ARCGIS_USERNAME="your_arcgis_username"
# ARCGIS_PASSWORD="your_arcgis_password" # Note: Storing passwords in .env is convenient but be mindful of security.
# ARCGIS_API_KEY="your_arcgis_api_key"
# ARCGIS_PROFILE_NAME="your_arcgis_python_api_profile_name" # For stored connection profiles

# Example for QGIS Client (if using specific prefix path for PyQGIS initialization):
# QGIS_PREFIX_PATH="C:/OSGeo4W/apps/qgis" # Or /usr, /usr/local, etc. on Linux/macOS

# Example for Dynamo Client (path to DynamoCLI if used):
# DYNAMOCLI_PATH="C:/Program Files/Dynamo Core/2.x/DynamoCLI.exe"


# --- General Notes ---
# - Lines starting with # are comments and will be ignored.
# - Ensure there are no extra spaces around the '=' sign.
# - Values are typically strings. If a value needs to contain spaces, it usually doesn't need quotes,
#   but some libraries might handle quoted strings. Check library documentation if unsure.
# - The `python-dotenv` library loads these variables into os.environ when `load_dotenv()` is called.
# - Make sure this .env.example file is committed to your repository, but the actual .env file (with secrets) is NOT.
#   Add `.env` to your `.gitignore` file.
