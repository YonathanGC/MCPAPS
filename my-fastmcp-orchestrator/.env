# FastMCP Configuration
FASTMCP_URL=ws://localhost
FASTMCP_PORT=8765
FASTMCP_TOKEN=your_fastmcp_token

# AI Controller Configuration (Gemini/Jules)
GEMINI_API_KEY=your_gemini_api_key
# Alternatively, for OAuth2 (example variables, adjust as needed)
# OAUTH_CLIENT_ID=your_oauth_client_id
# OAUTH_CLIENT_SECRET=your_oauth_client_secret
# OAUTH_TOKEN_URL=your_oauth_token_url
# OAUTH_SCOPES=your_oauth_scopes

# Application Specific Configurations (if any)
# Example:
# REVIT_PROJECT_DEFAULT_PATH="C:/Projects/MyRevitProject.rvt"
