# Anthropic Claude API Key
CLAUDE_API_KEY="YOUR_CLAUDE_API_KEY_HERE"

# Dlubal Application Server (gRPC)
# This is typically localhost if RFEM/RSTAB is running on the same machine.
# The DlubalController will use 'localhost:8081' by default if this is not set.
# DLUBAL_SERVER_ADDRESS="localhost:8081"

# FastMCP Server Configuration (Likely to be deprecated or re-purposed if directly controlling Dlubal)
# FASTMCP_SERVER_URL="ws://localhost:8080"
# FASTMCP_AUTH_TOKEN="YOUR_FASTMCP_AUTH_TOKEN_HERE"

# Other potential configurations
# LOG_LEVEL="INFO"
